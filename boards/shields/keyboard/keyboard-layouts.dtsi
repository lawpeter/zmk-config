/*
 * PRD §11 step 10 — Physical layout for ZMK Studio.
 *
 * All dimensions are in centi-keyunits (100 = 1 u).
 * Format: <&key_physical_attrs  W   H    X    Y  ROT  RX  RY>
 *
 * 68 keys total:
 *   Row 0 (y=  0): 14 keys — number row
 *   Row 1 (y=100): 14 keys — QWERTY
 *   Row 2 (y=200): 13 keys — home row (COL14 omitted — display cutout)
 *   Row 3 (y=300): 14 keys — bottom alpha + Del
 *   Row 4 (y=400): 13 keys — modifiers + arrows (COL7 omitted — physical gap)
 *
 * No entry for the encoder push button (RC(5,0)); Studio does not expose
 * it as a mappable key in the physical-layout keys list.
 */

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;

        keys  //                     w    h     x     y   rot  rx  ry
            /* ── Row 0: number row ─────────────────────────────────── */
            = <&key_physical_attrs 100  100     0     0     0   0   0>  /* ~ */
            , <&key_physical_attrs 100  100   100     0     0   0   0>  /* ! */
            , <&key_physical_attrs 100  100   200     0     0   0   0>  /* @ */
            , <&key_physical_attrs 100  100   300     0     0   0   0>  /* # */
            , <&key_physical_attrs 100  100   400     0     0   0   0>  /* $ */
            , <&key_physical_attrs 100  100   500     0     0   0   0>  /* % */
            , <&key_physical_attrs 100  100   600     0     0   0   0>  /* ^ */
            , <&key_physical_attrs 100  100   700     0     0   0   0>  /* & */
            , <&key_physical_attrs 100  100   800     0     0   0   0>  /* * */
            , <&key_physical_attrs 100  100   900     0     0   0   0>  /* ( */
            , <&key_physical_attrs 100  100  1000     0     0   0   0>  /* ) */
            , <&key_physical_attrs 100  100  1100     0     0   0   0>  /* _ */
            , <&key_physical_attrs 100  100  1200     0     0   0   0>  /* + */
            , <&key_physical_attrs 175  100  1300     0     0   0   0>  /* Backspace 1.75u */

            /* ── Row 1: QWERTY ──────────────────────────────────────── */
            , <&key_physical_attrs 150  100     0   100     0   0   0>  /* Tab 1.5u */
            , <&key_physical_attrs 100  100   150   100     0   0   0>  /* Q */
            , <&key_physical_attrs 100  100   250   100     0   0   0>  /* W */
            , <&key_physical_attrs 100  100   350   100     0   0   0>  /* E */
            , <&key_physical_attrs 100  100   450   100     0   0   0>  /* R */
            , <&key_physical_attrs 100  100   550   100     0   0   0>  /* T */
            , <&key_physical_attrs 100  100   650   100     0   0   0>  /* Y */
            , <&key_physical_attrs 100  100   750   100     0   0   0>  /* U */
            , <&key_physical_attrs 100  100   850   100     0   0   0>  /* I */
            , <&key_physical_attrs 100  100   950   100     0   0   0>  /* O */
            , <&key_physical_attrs 100  100  1050   100     0   0   0>  /* P */
            , <&key_physical_attrs 100  100  1150   100     0   0   0>  /* { */
            , <&key_physical_attrs 100  100  1250   100     0   0   0>  /* } */
            , <&key_physical_attrs 125  100  1350   100     0   0   0>  /* | 1.25u */

            /* ── Row 2: home row (13 keys; COL14 = display cutout) ─── */
            , <&key_physical_attrs 175  100     0   200     0   0   0>  /* CapsLock 1.75u */
            , <&key_physical_attrs 100  100   175   200     0   0   0>  /* A */
            , <&key_physical_attrs 100  100   275   200     0   0   0>  /* S */
            , <&key_physical_attrs 100  100   375   200     0   0   0>  /* D */
            , <&key_physical_attrs 100  100   475   200     0   0   0>  /* F */
            , <&key_physical_attrs 100  100   575   200     0   0   0>  /* G */
            , <&key_physical_attrs 100  100   675   200     0   0   0>  /* H */
            , <&key_physical_attrs 100  100   775   200     0   0   0>  /* J */
            , <&key_physical_attrs 100  100   875   200     0   0   0>  /* K */
            , <&key_physical_attrs 100  100   975   200     0   0   0>  /* L */
            , <&key_physical_attrs 100  100  1075   200     0   0   0>  /* : */
            , <&key_physical_attrs 100  100  1175   200     0   0   0>  /* " */
            , <&key_physical_attrs 200  100  1275   200     0   0   0>  /* Enter 2u */

            /* ── Row 3: bottom alpha ────────────────────────────────── */
            , <&key_physical_attrs 225  100     0   300     0   0   0>  /* Shift 2.25u */
            , <&key_physical_attrs 100  100   225   300     0   0   0>  /* Z */
            , <&key_physical_attrs 100  100   325   300     0   0   0>  /* X */
            , <&key_physical_attrs 100  100   425   300     0   0   0>  /* C */
            , <&key_physical_attrs 100  100   525   300     0   0   0>  /* V */
            , <&key_physical_attrs 100  100   625   300     0   0   0>  /* B */
            , <&key_physical_attrs 100  100   725   300     0   0   0>  /* N */
            , <&key_physical_attrs 100  100   825   300     0   0   0>  /* M */
            , <&key_physical_attrs 100  100   925   300     0   0   0>  /* < */
            , <&key_physical_attrs 100  100  1025   300     0   0   0>  /* > */
            , <&key_physical_attrs 100  100  1125   300     0   0   0>  /* ? */
            , <&key_physical_attrs 150  100  1225   300     0   0   0>  /* RShift 1.5u */
            , <&key_physical_attrs 100  100  1375   300     0   0   0>  /* Up */
            , <&key_physical_attrs 100  100  1475   300     0   0   0>  /* Del (MX55) */

            /* ── Row 4: modifiers (13 keys; COL7 = physical gap) ───── */
            , <&key_physical_attrs 150  100     0   400     0   0   0>  /* LCTRL 1.5u */
            , <&key_physical_attrs 150  100   150   400     0   0   0>  /* LGUI 1.5u */
            , <&key_physical_attrs 150  100   300   400     0   0   0>  /* LALT 1.5u */
            , <&key_physical_attrs 100  100   450   400     0   0   0>  /* CMD/MX59 1u */
            , <&key_physical_attrs 200  100   550   400     0   0   0>  /* Space1 2u */
            , <&key_physical_attrs 125  100   750   400     0   0   0>  /* RALT 1.25u */
            , <&key_physical_attrs 200  100   875   400     0   0   0>  /* Space2 2u */
            , <&key_physical_attrs 150  100  1075   400     0   0   0>  /* FN1 1.5u */
            , <&key_physical_attrs 150  100  1225   400     0   0   0>  /* FN2 1.5u */
            , <&key_physical_attrs 100  100  1375   400     0   0   0>  /* RCTRL/MX65 1u */
            , <&key_physical_attrs 100  100  1475   400     0   0   0>  /* Left */
            , <&key_physical_attrs 100  100  1575   400     0   0   0>  /* Down */
            , <&key_physical_attrs 100  100  1675   400     0   0   0>  /* Right */
            ;
    };
};
