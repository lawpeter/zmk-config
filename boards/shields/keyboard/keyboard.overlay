#include <dt-bindings/zmk/matrix_transform.h>

/* PRD §11 step 2: real 5x14 matrix.
 * Rows are nRF GPIO inputs; columns are MCP23017 outputs driven over I2C.
 * Diode direction is col2row (verified from the PCB: each diode's cathode sits
 * on the ROW net, anode on the switch/column side -> current flows col->row).
 * Keeping the row inputs on the nRF lets GPIO sense wake the MCU from deep
 * sleep; the MCP23017 INT line is not wired to the nRF, so the expander must
 * stay on the output (strobe) side.
 *
 * PRD §11 step 5: EC11E encoder added.
 * - Rotation sensor: alps,ec11 on P0.17 (A) / P0.08 (B), steps=60
 * - Push button:     zmk,kscan-gpio-direct on P0.20 (active-low + pull-up)
 * - The matrix (rows 0-4) and push button (row 5) are merged via
 *   zmk,kscan-composite; the composite becomes the chosen zmk,kscan.
 * - Matrix transform gains a 69th key: RC(5,0) = encoder push.           */

/* ── SPI1 pinctrl override ────────────────────────────────────────────────────
 * The board's default spi1 pinctrl (SCK=P1.13, MOSI=P0.10, MISO=P1.11) uses
 * pins that are all occupied in this design (P1.13=ROW5, P0.10=nice!view SCK,
 * P1.11=nice!view MOSI). Override to our actual PCB wiring:
 *   MOSI = P1.11 (pad 22)   SCK = P0.10 (pad 23)   CS = P0.09 (pad 24, GPIO)
 * MISO is not connected (display is write-only). P0.25 is an internal nRF pin
 * not routed to any nice!nano pad; it is used here as a harmless dummy MISO so
 * the driver is satisfied without leaving the field empty.                   */
&spi1_default {
    group1 {
        psels = <NRF_PSEL(SPIM_MOSI, 1, 11)>,
                <NRF_PSEL(SPIM_SCK,  0, 10)>,
                <NRF_PSEL(SPIM_MISO, 0, 25)>;
    };
};

&spi1_sleep {
    group1 {
        psels = <NRF_PSEL(SPIM_MOSI, 1, 11)>,
                <NRF_PSEL(SPIM_SCK,  0, 10)>,
                <NRF_PSEL(SPIM_MISO, 0, 25)>;
        low-power-enable;
    };
};

/* Expose spi1 under the nice_view_spi alias that the nice_view shield requires.
 * Our keyboard.zmk.yml exposes [nice_view_header] so no adapter shield is needed.
 * CS is managed by the SPI controller via gpio: P0.09 (pad 24), active-high.  */
nice_view_spi: &spi1 {
    status = "okay";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
};

/* ── I2C0 pinctrl override ───────────────────────────────────────────────────
 * Override the board's default I2C0 pins (P0.17/P0.20) so the encoder can use
 * those pins later. Hardware routes I2C to P1.07 (SDA) / P1.02 (SCL). No
 * external pull-ups on the bus, so enable the nRF internal ones. These extend
 * the existing board pinctrl states by label, replacing their psels.         */
&i2c0_default {
    group1 {
        psels = <NRF_PSEL(TWIM_SDA, 1, 7)>, <NRF_PSEL(TWIM_SCL, 1, 2)>;
        bias-pull-up;
    };
};

&i2c0_sleep {
    group1 {
        psels = <NRF_PSEL(TWIM_SDA, 1, 7)>, <NRF_PSEL(TWIM_SCL, 1, 2)>;
        low-power-enable;
    };
};

&i2c0 {
    status = "okay";
    clock-frequency = <100000>;   /* standard mode, 100 kHz (PRD §2.3) */

    mcp23017: mcp23017@20 {
        compatible = "microchip,mcp230xx";
        status = "okay";
        gpio-controller;
        reg = <0x20>;
        #gpio-cells = <2>;
        ngpios = <16>;
    };
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /* ── Key matrix (rows 0-4 of the composite) ──────────────────────────── */

    /* Renamed from kscan0; now a sub-scanner inside the composite.
     * wakeup-source stays here so the composite can propagate it to this
     * child and the nRF row GPIOs can still trigger deep-sleep wake. */
    kscan_matrix: kscan_matrix {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        /* Outputs (strobe), on the MCP23017. GPA0..7 = 0..7, GPB0..7 = 8..15. */
        col-gpios
            = <&mcp23017 15 GPIO_ACTIVE_HIGH>   /* COL1  GPB7 */
            , <&mcp23017 14 GPIO_ACTIVE_HIGH>   /* COL2  GPB6 */
            , <&mcp23017 13 GPIO_ACTIVE_HIGH>   /* COL3  GPB5 */
            , <&mcp23017 12 GPIO_ACTIVE_HIGH>   /* COL4  GPB4 */
            , <&mcp23017 11 GPIO_ACTIVE_HIGH>   /* COL5  GPB3 */
            , <&mcp23017 10 GPIO_ACTIVE_HIGH>   /* COL6  GPB2 */
            , <&mcp23017  9 GPIO_ACTIVE_HIGH>   /* COL7  GPB1 */
            , <&mcp23017  8 GPIO_ACTIVE_HIGH>   /* COL8  GPB0 */
            , <&mcp23017  3 GPIO_ACTIVE_HIGH>   /* COL9  GPA3 */
            , <&mcp23017  4 GPIO_ACTIVE_HIGH>   /* COL10 GPA4 */
            , <&mcp23017  5 GPIO_ACTIVE_HIGH>   /* COL11 GPA5 */
            , <&mcp23017  6 GPIO_ACTIVE_HIGH>   /* COL12 GPA6 */
            , <&mcp23017  7 GPIO_ACTIVE_HIGH>   /* COL13 GPA7 */
            , <&mcp23017  2 GPIO_ACTIVE_HIGH>   /* COL14 GPA2 */
            ;

        /* Inputs (sense), on the nRF. */
        row-gpios
            = <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW1 P0.31 */
            , <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW2 P0.29 */
            , <&gpio0  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW3 P0.02 */
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW4 P1.15 */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW5 P1.13 */
            ;
    };

    /* ── Encoder push button (row 5 of the composite) ────────────────────── */

    /* EC11E push switch S1 on P0.20; S2 tied to GND → active-low. */
    kscan_encoder_btn: kscan_encoder_btn {
        compatible = "zmk,kscan-gpio-direct";
        input-gpios = <&gpio0 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    /* ── Composite kscan (chosen zmk,kscan) ──────────────────────────────── */

    /* Merges the 5-row matrix and the 1-key encoder push button.
     * row-offset=5 places the push button at RC(5,0) in the transform.
     * wakeup-source here enables PM wakeup propagation to capable children. */
    kscan0: kscan0 {
        compatible = "zmk,kscan-composite";
        rows = <6>;
        columns = <14>;
        wakeup-source;

        matrix {
            kscan = <&kscan_matrix>;
        };

        encoder_btn {
            kscan = <&kscan_encoder_btn>;
            row-offset = <5>;
        };
    };

    /* ── EC11E rotary encoder ─────────────────────────────────────────────── */

    /* PRD §2.6: A=P0.17 (pad 5), B=P0.08 (pad 2), steps=60 (60 quadrature
     * transitions per revolution; 30 detents × 2 transitions/detent).
     * Internal pull-ups required — no external pull-ups on PCB.
     * triggers-per-rotation=30 in the sensors node → one action per detent. */
    encoder: encoder {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio0  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <60>;
        status = "okay";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <30>;   /* 30 detents/rev → one trigger per click */
    };

    /* ── Matrix transform (68 switch keys + 1 encoder push = 69 total) ───── */

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <6>;   /* 5 matrix rows + 1 virtual row for encoder push */

        /* Row 3 omits COL14 and row 5 omits COL7 (physical gaps, PRD §3).
         * Row 6 (index 5) has one key: the encoder push button at RC(5,0). */
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,12) RC(4,13)
RC(5,0)
        >;
    };
};
