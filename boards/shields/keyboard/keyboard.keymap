#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/* PRD §11 step 4: FN + FN2 layers.
 *
 * Layer structure:
 *   0  default_layer — base QWERTY (Step 3)
 *   1  fn_layer      — F1-F12, navigation                 (hold FN1/MX63)
 *   2  fn2_layer     — BT management, USB/BLE output toggle (hold FN2/MX64)  */

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
/* ── Row 0: number row ─────────────────────────────────────────────────────── */
&kp GRAVE &kp N1 &kp N2 &kp N3 &kp N4 &kp N5 &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &kp MINUS &kp EQUAL &kp BSPC
/* ── Row 1: QWERTY ──────────────────────────────────────────────────────────── */
&kp TAB   &kp Q  &kp W  &kp E  &kp R  &kp T  &kp Y  &kp U  &kp I  &kp O  &kp P  &kp LBKT  &kp RBKT  &kp BSLH
/* ── Row 2: home row (13 keys; COL14 omitted — display cutout) ──────────────── */
&kp CAPS  &kp A  &kp S  &kp D  &kp F  &kp G  &kp H  &kp J  &kp K  &kp L  &kp SEMI &kp APOS &kp RET
/* ── Row 3: bottom alpha (MX55/COL14 = Del; adjustable) ────────────────────── */
&kp LSHFT &kp Z  &kp X  &kp C  &kp V  &kp B  &kp N  &kp M  &kp COMMA &kp DOT &kp FSLH &kp RSHFT &kp UP &kp DEL
/* ── Row 4: modifiers (13 keys; COL7 omitted — physical gap) ───────────────── *
 * COL1     COL2   COL3   COL4(MX59)  COL5        COL6                           *
 * LCTRL    LGUI   LALT   LGUI(CMD)*  Space1(2u)  RALT    [gap]                  *
 *                  COL8        COL9   COL10  COL11(MX65)  COL12  COL13  COL14   *
 *                  Space2(2u)  FN1    FN2    RCTRL**      Left   Down   Right   *
 * * MX59: extra Apple CMD key — adjustable via Studio or here                   *
 * **MX65: extra Right Ctrl    — adjustable via Studio or here                   */
&kp LCTRL &kp LGUI &kp LALT &kp LGUI &kp SPACE &kp RALT &kp SPACE &mo 1 &mo 2 &kp RCTRL &kp LEFT &kp DOWN &kp RIGHT
            >;
        };

        fn_layer {
            /* PRD §5.2 — hold FN1 (COL9/MX63) to activate.
             *
             * Number row:  1-0 → F1-F10,  - → F11,  = → F12,  Bksp → Del
             * Navigation:  UP → PgUp,  Left → Home,  Down → PgDn,  Right → End
             * RSHFT → &trans  (TODO Step 10: replace with &studio_unlock)
             * T     → &trans  (TODO Step 9:  replace with &typing_test_toggle)  */
            bindings = <
/* Row 0 — number row: F1-F12 + Del */
&trans  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &kp F11  &kp F12  &kp DEL
/* Row 1 — all transparent */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
/* Row 2 — home row */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
/* Row 3 — RSHFT placeholder; UP → PgUp */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp PG_UP  &trans
/* Row 4 — arrows: Left → Home, Down → PgDn, Right → End */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp HOME  &kp PG_DN  &kp END
            >;
        };

        fn2_layer {
            /* PRD §5.3 — hold FN2 (COL10/MX64) to activate.
             *
             * Number row:
             *   1-5 → BT profile select 0-4       (wireless device switching)
             *   6   → BT clear current profile
             *   7   → BT_NXT  (cycle forward)
             *   8   → BT_PRV  (cycle backward)
             * Backslash → OUT_TOG  (toggle USB / BLE output)
             * All other keys transparent — user fills via ZMK Studio.
             * Encoder bindings (SCRL_UP/SCRL_DN/MCLK) added in Step 5.          */
            bindings = <
/* Row 0 — BT management */
&trans  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_CLR  &bt BT_NXT  &bt BT_PRV  &trans  &trans  &trans  &trans  &trans
/* Row 1 — backslash → OUT_TOG */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &out OUT_TOG
/* Row 2 — home row */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
/* Row 3 */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
/* Row 4 */
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
