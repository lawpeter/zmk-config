#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/* PLACEHOLDER skeleton keymap (PRD §11 step 1).
 * Step 3 replaces this with the full QWERTY base layer. */

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp A &kp B
                &kp C &kp D
            >;
        };
    };
};
